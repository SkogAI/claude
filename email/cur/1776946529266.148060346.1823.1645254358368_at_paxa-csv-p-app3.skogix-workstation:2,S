    <p style="margin-top:0;margin-bottom:0px;">
      <img alt="Grupp av människor äter mat under ett träd" style="max-width:800px;" src="https://res.cloudinary.com/coopsverige/image/upload/v1571829015/CRM/2019/blimedlem/coop_online_medlem_v43_2019_1200x310px.jpg">
