{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "cleanupPeriodDays": 90,
  "env": {
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(gita *)",
      "Bash(gptodo *)",
      "Bash(gh *)",
      "Bash(skogai *)",
      "Bash(argc *)",
      "Bash(skogcli *)",
      "Skill(gsd:*)",
      "Skill(skogai-routing:*)",
      "Skill(skogai-bats-testing:*)",
      "Bash(wt *)"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "/home/skogix/claude/"
    ]
  },
  "enableAllProjectMcpServers": false,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-check-update.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-context-monitor.js"
          }
        ]
      }
    ]
  },
  "disableAllHooks": false,
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/gsd-statusline.js"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": false,
    "linear@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "worktrunk@worktrunk": false,
    "claude-memory@skogai-marketplace": true,
    "core@skogai-marketplace": false,
    "dreamers@skogai-marketplace": false,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "mintlify@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "worktrunk": {
      "source": {
        "source": "directory",
        "path": "/home/skogix/.local/src/worktrunk"
      }
    },
    "skogai-marketplace": {
      "source": {
        "source": "directory",
        "path": "/home/skogix/.local/src/marketplace"
      },
      "autoUpdate": true
    }
  },
  "spinnerTipsEnabled": true,
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "showTurnDuration": true,
  "terminalProgressBarEnabled": true
}
