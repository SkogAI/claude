# Git identity for Claude agents working in this repo
# Applied via repo-level git config (user.name, user.email, commit.gpgsign)
# This file is a portable reference; the repo config is the source of truth

[user]
    name = Claude (SkogAI)
    email = claude@skogai.dev

[commit]
    gpgsign = false

[init]
    defaultBranch = master
